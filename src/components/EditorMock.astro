---
// Builder editor mock — modelled on the supplied reference (Pages/Portfolio,
// component library, dark hero on the canvas). Plain CSS, brand = Pagistry indigo.

const ic = {
  search: '<circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/>',
  sparkle: '<path d="M12 3l1.7 4.8L18.5 9l-4.8 1.2L12 15l-1.7-4.8L5.5 9l4.8-1.2z"/><path d="M19 14l.6 1.7 1.9.6-1.9.6-.6 1.7-.6-1.7-1.9-.6 1.9-.6z"/>',
  minus: '<path d="M5 12h14"/>',
  plus: '<path d="M12 5v14M5 12h14"/>',
  monitor: '<rect x="3" y="4" width="18" height="12" rx="2"/><path d="M8 20h8M12 16v4"/>',
  tablet: '<rect x="6" y="3" width="12" height="18" rx="2"/><path d="M12 17h.01"/>',
  phone: '<rect x="8" y="3" width="8" height="18" rx="2"/><path d="M12 17h.01"/>',
  undo: '<path d="M9 14 4 9l5-5"/><path d="M4 9h11a5 5 0 0 1 0 10H8"/>',
  redo: '<path d="M15 14l5-5-5-5"/><path d="M20 9H9a5 5 0 0 0 0 10h8"/>',
  tree: '<circle cx="12" cy="5" r="2"/><circle cx="6" cy="19" r="2"/><circle cx="18" cy="19" r="2"/><path d="M12 7v3M6 17v-2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2"/>',
  eye: '<path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z"/><circle cx="12" cy="12" r="3"/>',
  history: '<path d="M3 12a9 9 0 1 0 3-6.7L3 8"/><path d="M3 3v5h5"/><path d="M12 8v4l3 2"/>',
  download: '<path d="M12 4v10m0 0 4-4m-4 4-4-4"/><path d="M5 19h14"/>',
  refresh: '<path d="M21 12a9 9 0 1 1-3-6.7"/><path d="M21 4v4h-4"/>',
  save: '<path d="M5 4h11l3 3v13H5z"/><path d="M8 4v5h7M8 20v-6h8v6"/>',
  rocket: '<path d="M5 15c-1 1.6-1 4-1 4s2.4 0 4-1m-3-3a9 9 0 0 1 9-9c2.6 0 4 1.4 4 4a9 9 0 0 1-9 9z"/><circle cx="14.5" cy="9.5" r="1.3"/>',
  // rail
  blocks: '<rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/>',
  layers: '<path d="M12 3 3 8l9 5 9-5z"/><path d="M3 13l9 5 9-5"/>',
  pages: '<rect x="5" y="3" width="14" height="18" rx="2"/><path d="M9 8h6M9 12h6M9 16h4"/>',
  site: '<rect x="3" y="4" width="18" height="16" rx="2"/><path d="M3 9h18"/>',
  design: '<circle cx="12" cy="12" r="9"/><circle cx="8.5" cy="10" r="1"/><circle cx="12" cy="8" r="1"/><circle cx="15.5" cy="10" r="1"/>',
  globe: '<circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.5 2.5 2.5 15 0 18M12 3c-2.5 2.5-2.5 15 0 18"/>',
  cms: '<ellipse cx="12" cy="6" rx="8" ry="3"/><path d="M4 6v12c0 1.7 3.6 3 8 3s8-1.3 8-3V6"/><path d="M4 12c0 1.7 3.6 3 8 3s8-1.3 8-3"/>',
  connect: '<path d="M10 13a4 4 0 0 1 0-6l1-1a4 4 0 0 1 6 6l-1 1"/><path d="M14 11a4 4 0 0 1 0 6l-1 1a4 4 0 0 1-6-6l1-1"/>',
  // component cards
  navbar: '<rect x="3" y="5" width="18" height="5" rx="1.5"/><path d="M6 7.5h2M14 7.5h4"/>',
  hero: '<rect x="3" y="4" width="18" height="16" rx="2"/><path d="M7 10h10M7 14h6"/>',
  pricing: '<rect x="3" y="6" width="18" height="12" rx="2"/><path d="M3 10h18M7 14h3"/>',
  testimonial: '<path d="M6 7h4v5H8l-2 3zM14 7h4v5h-2l-2 3z"/>',
  stats: '<path d="M5 20V11M10 20V5M15 20V9M20 20v-6"/><path d="M4 20h17"/>',
  form: '<rect x="3" y="6" width="18" height="12" rx="2"/><path d="m3 8 9 6 9-6"/>',
  footer: '<rect x="3" y="14" width="18" height="5" rx="1.5"/><path d="M6 16.5h6"/>',
  collection: '<rect x="3" y="4" width="18" height="4" rx="1"/><rect x="3" y="10" width="18" height="4" rx="1"/><rect x="3" y="16" width="18" height="4" rx="1"/>',
  bag: '<path d="M6 8h12l-1 12H7zM9 8a3 3 0 0 1 6 0"/>',
  package: '<path d="M12 3 4 7v10l8 4 8-4V7z"/><path d="M4 7l8 4 8-4M12 11v10"/>',
  cartPlus: '<circle cx="9" cy="20" r="1.4"/><circle cx="17" cy="20" r="1.4"/><path d="M3 4h2l2 12h11"/><path d="M15 5v5M12.5 7.5h5"/>',
  cart: '<circle cx="9" cy="20" r="1.4"/><circle cx="17" cy="20" r="1.4"/><path d="M3 4h2l2.4 12h10L20 8H6"/>',
  checkout: '<rect x="3" y="6" width="18" height="12" rx="2"/><path d="M3 10h18M7 14.5l2 2 4-4"/>',
};

const rail = [
  { label: 'Blocks', icon: 'blocks', active: true },
  { label: 'Layers', icon: 'layers' },
  { label: 'Pages', icon: 'pages' },
  { label: 'Site', icon: 'site' },
  { label: 'Design', icon: 'design' },
  { label: 'SEO', icon: 'globe' },
  { label: 'CMS', icon: 'cms' },
  { label: 'Connect', icon: 'connect' },
];

const components = [
  { label: 'Navbar', icon: 'navbar' },
  { label: 'Hero', icon: 'hero' },
  { label: 'Feature grid', icon: 'blocks' },
  { label: 'Pricing', icon: 'pricing' },
  { label: 'Testimonial', icon: 'testimonial' },
  { label: 'Stats', icon: 'stats' },
  { label: 'Call to action', icon: 'rocket' },
  { label: 'Form', icon: 'form' },
  { label: 'Footer', icon: 'footer' },
];
const commerce = [
  { label: 'Product Grid', icon: 'bag' },
  { label: 'Product', icon: 'package' },
  { label: 'Add to Cart', icon: 'cartPlus' },
  { label: 'Cart', icon: 'cart' },
  { label: 'Checkout', icon: 'checkout' },
];
---

<div class="em" role="img" aria-label="Pagistry website builder editor">
  <!-- Top bar -->
  <div class="em-top">
    <div class="em-top__left">
      <span class="em-logo" aria-hidden="true">
        <i></i><i></i><i></i><i></i>
      </span>
      <span class="em-crumb">
        <span class="em-crumb__muted">Pages</span>
        <svg class="em-ic em-ic--xs" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 6 6 6-6 6"/></svg>
        <span class="em-crumb__cur">Portfolio</span>
      </span>
      <span class="em-search">
        <svg class="em-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={ic.search}></svg>
        <span>Search</span>
        <kbd>⌘K</kbd>
      </span>
      <span class="em-ai">
        <svg class="em-ic" viewBox="0 0 24 24" fill="none" stroke="var(--br)" stroke-width="1.6" stroke-linejoin="round" set:html={ic.sparkle}></svg>
        AI
      </span>
    </div>

    <div class="em-top__center">
      <span class="em-zoom">
        <svg class="em-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" set:html={ic.minus}></svg>
        <span class="em-zoom__val">100%</span>
        <svg class="em-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" set:html={ic.plus}></svg>
      </span>
      <span class="em-devices">
        <span class="em-dev is-active"><svg class="em-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={ic.monitor}></svg></span>
        <span class="em-dev"><svg class="em-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={ic.tablet}></svg></span>
        <span class="em-dev"><svg class="em-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={ic.phone}></svg></span>
      </span>
    </div>

    <div class="em-top__right">
      <span class="em-iconbtn"><svg class="em-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={ic.undo}></svg></span>
      <span class="em-iconbtn"><svg class="em-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={ic.redo}></svg></span>
      <span class="em-vsep"></span>
      <span class="em-iconbtn"><svg class="em-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={ic.eye}></svg></span>
      <span class="em-saved em-hide-sm"><span class="em-saved__dot"></span>Saved</span>
      <span class="em-publish">
        <svg class="em-ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={ic.rocket}></svg>
        Publish
      </span>
    </div>
  </div>

  <!-- Body -->
  <div class="em-body">
    <!-- Icon rail -->
    <nav class="em-rail" aria-label="Editor sections">
      {
        rail.map((r) => (
          <span class:list={['em-rail__item', r.active && 'is-active']}>
            <svg class="em-ic em-ic--rail" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={ic[r.icon as keyof typeof ic]} />
            <span>{r.label}</span>
          </span>
        ))
      }
    </nav>

    <!-- Components panel -->
    <aside class="em-panel" aria-label="Components">
      <p class="em-panel__title">Components</p>

      <div class="em-cards">
        {
          components.map((c) => (
            <span class="em-card">
              <svg class="em-ic em-ic--card" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={ic[c.icon as keyof typeof ic]} />
              <span>{c.label}</span>
            </span>
          ))
        }
      </div>

      <div class="em-sec">
        <span>Dynamic</span>
        <svg class="em-ic em-ic--xs" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
      </div>
      <div class="em-cards">
        <span class="em-card">
          <svg class="em-ic em-ic--card" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={ic.collection} />
          <span>Collection List</span>
        </span>
      </div>

      <div class="em-sec">
        <span>Commerce</span>
        <svg class="em-ic em-ic--xs" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
      </div>
      <div class="em-cards">
        {
          commerce.map((c) => (
            <span class="em-card">
              <svg class="em-ic em-ic--card" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={ic[c.icon as keyof typeof ic]} />
              <span>{c.label}</span>
            </span>
          ))
        }
      </div>

      <div class="em-sec">
        <span class="em-sec__my"><svg class="em-ic em-ic--xs" viewBox="0 0 24 24" fill="none" stroke="var(--br)" stroke-width="1.6" set:html={ic.sparkle}></svg> My components</span>
      </div>
      <div class="em-mycomp">
        No saved components yet. Select a block and choose <b>Save as component</b> to reuse it everywhere.
      </div>
    </aside>

    <!-- Canvas (light skeleton page) -->
    <main class="em-canvas" aria-label="Page canvas">
      <div class="em-doc" aria-hidden="true">
        <!-- selected hero block -->
        <div class="em-sk em-sk--sel">
          <span class="em-sk__tag">Hero</span>
          <span class="em-sk-pill sk"></span>
          <span class="em-sk-bar em-sk-bar--h sk" style="width:74%"></span>
          <span class="em-sk-bar em-sk-bar--h sk" style="width:54%"></span>
          <span class="em-sk-bar sk" style="width:64%"></span>
          <span class="em-sk-bar sk" style="width:48%"></span>
          <span class="em-sk-btn sk"></span>
        </div>

        <!-- feature grid -->
        <div class="em-sk-row">
          {
            [0, 1, 2].map(() => (
              <div class="em-sk-card">
                <span class="em-sk-ico sk" />
                <span class="em-sk-bar sk" style="width:70%" />
                <span class="em-sk-bar sk" style="width:90%" />
                <span class="em-sk-bar sk" style="width:55%" />
              </div>
            ))
          }
        </div>

        <!-- split block -->
        <div class="em-sk-split">
          <div class="em-sk-img sk"></div>
          <div class="em-sk-col">
            <span class="em-sk-bar em-sk-bar--h sk" style="width:58%"></span>
            <span class="em-sk-bar sk" style="width:92%"></span>
            <span class="em-sk-bar sk" style="width:84%"></span>
            <span class="em-sk-bar sk" style="width:66%"></span>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>

<style lang="scss">
  .em {
    --g50: #f8f8fa;
    --g100: #f1f1f4;
    --g200: #e7e7ec;
    --g300: #d3d3da;
    --g400: #9a9aa6;
    --g500: #6c6c79;
    --g600: #4d4d59;
    --g700: #3a3a45;
    --g800: #232730;
    --g900: #14161d;
    --br: #5b3df5;
    --ink: #16161d;

    position: relative;
    width: 100%;
    overflow: hidden;
    user-select: none;
    border-radius: 16px;
    border: 1px solid var(--g200);
    background: #fff;
    box-shadow:
      0 34px 64px -32px rgba(16, 16, 22, 0.18),
      0 10px 26px -16px rgba(16, 16, 22, 0.07);
    font-family: var(--font-body);
    color: var(--g700);
    line-height: 1.2;
  }
  .em *,
  .em *::before,
  .em *::after {
    box-sizing: border-box;
  }
  .em-ic {
    width: 15px;
    height: 15px;
    flex: none;
  }
  .em-ic--xs {
    width: 12px;
    height: 12px;
  }
  .em-ic--rail {
    width: 18px;
    height: 18px;
  }
  .em-ic--card {
    width: 18px;
    height: 18px;
    color: var(--g700);
  }

  /* ---------------- Top bar ---------------- */
  .em-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    height: 52px;
    padding: 0 12px;
    border-bottom: 1px solid var(--g100);
    background: #fff;
  }
  .em-top__left,
  .em-top__center,
  .em-top__right {
    display: flex;
    align-items: center;
    gap: 8px;
    min-width: 0;
  }
  .em-top__center {
    gap: 10px;
  }

  .em-logo {
    display: inline-grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    width: 26px;
    height: 26px;
    flex: none;
    padding: 5px;
    border-radius: 7px;
    background: var(--br);
  }
  .em-logo i {
    border-radius: 1.5px;
    background: #fff;
  }
  .em-logo i:nth-child(2),
  .em-logo i:nth-child(3) {
    background: var(--logo-accent);
  }

  .em-crumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12.5px;
    flex: none;
  }
  .em-crumb__muted {
    color: var(--g500);
    font-weight: 500;
  }
  .em-crumb svg {
    color: var(--g300);
  }
  .em-crumb__cur {
    color: var(--ink);
    font-weight: 700;
  }

  .em-search {
    display: flex;
    align-items: center;
    gap: 7px;
    height: 28px;
    padding: 0 9px;
    border-radius: 8px;
    background: var(--g100);
    color: var(--g400);
    font-size: 11.5px;
  }
  .em-search kbd {
    font-family: inherit;
    font-size: 9.5px;
    color: var(--g500);
    background: #fff;
    border: 1px solid var(--g200);
    border-radius: 4px;
    padding: 1px 4px;
  }
  .em-ai {
    display: flex;
    align-items: center;
    gap: 5px;
    height: 28px;
    padding: 0 10px;
    border-radius: 8px;
    background: var(--lavender-surface);
    color: var(--br);
    font-size: 12px;
    font-weight: 600;
  }

  /* center cluster */
  .em-zoom,
  .em-devices {
    display: flex;
    align-items: center;
    gap: 2px;
    height: 28px;
    padding: 0 4px;
    border-radius: 8px;
    border: 1px solid var(--g200);
    color: var(--g500);
  }
  .em-zoom__val {
    font-size: 11px;
    font-weight: 600;
    color: var(--g700);
    padding: 0 4px;
  }
  .em-zoom .em-ic {
    width: 13px;
    height: 13px;
  }
  .em-dev {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 22px;
    border-radius: 6px;
    color: var(--g500);
  }
  .em-dev.is-active {
    background: var(--ink);
    color: #fff;
  }
  .em-canvas-w {
    font-size: 11px;
    color: var(--g500);
    font-variant-numeric: tabular-nums;
  }

  /* right cluster */
  .em-iconbtn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 7px;
    color: var(--g500);
  }
  .em-vsep {
    width: 1px;
    height: 18px;
    background: var(--g200);
    margin: 0 2px;
  }
  .em-saved {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 11.5px;
    color: var(--g500);
    margin: 0 2px;
  }
  .em-saved__dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: #22c55e;
  }
  .em-publish {
    display: flex;
    align-items: center;
    gap: 5px;
    height: 30px;
    padding: 0 13px;
    border-radius: 9px;
    background: var(--ink);
    color: #fff;
    font-size: 12px;
    font-weight: 600;
  }
  .em-publish .em-ic {
    width: 13px;
    height: 13px;
  }

  /* ---------------- Body ---------------- */
  .em-body {
    display: grid;
    grid-template-columns: 72px 230px 1fr;
    height: 432px;
  }

  /* Rail */
  .em-rail {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 16px 10px;
    border-right: 1px solid var(--g100);
    background: #fff;
    overflow: hidden;
  }
  .em-rail__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    padding: 10px 0 9px;
    border-radius: 10px;
    color: var(--g500);
    font-size: 8.5px;
    font-weight: 500;
  }
  .em-rail__item.is-active {
    background: var(--lavender-surface);
    color: var(--br);
  }

  /* Components panel */
  .em-panel {
    border-right: 1px solid var(--g100);
    background: #fff;
    padding: 18px 18px;
    overflow: hidden;
  }
  .em-panel__title {
    margin: 0 0 14px;
    font-size: 14px;
    font-weight: 700;
    color: var(--ink);
  }
  .em-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 9px;
  }
  .em-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 7px;
    aspect-ratio: 1 / 0.92;
    border-radius: 11px;
    border: 1px solid var(--g200);
    background: #fff;
    color: var(--g600);
    font-size: 9px;
    font-weight: 500;
    text-align: center;
    padding: 4px;
  }
  .em-sec {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin: 16px 0 8px;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--g400);
  }
  .em-sec svg {
    color: var(--g400);
  }
  .em-sec__my {
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .em-mycomp {
    border: 1px dashed var(--g300);
    border-radius: 11px;
    padding: 12px;
    font-size: 9.5px;
    line-height: 1.45;
    color: var(--g400);
  }
  .em-mycomp b {
    color: var(--g600);
    font-weight: 600;
  }

  /* Canvas — light skeleton page */
  .em-canvas {
    background: #ededf0;
    background-image: radial-gradient(circle, rgba(0, 0, 0, 0.05) 1px, transparent 1px);
    background-size: 20px 20px;
    padding: 16px;
    overflow: hidden;
  }
  .em-doc {
    height: 100%;
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 2px 10px -4px rgba(16, 16, 22, 0.12);
    border: 1px solid var(--g200);
    overflow: hidden;
    padding: 16px 16px 0;
  }

  /* Skeleton fills */
