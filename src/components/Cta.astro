---
import { SIGNUP_URL } from '../config';
---

<section class="cta" id="cta">
  <div class="grid-overlay"></div>
  <div class="container cta__inner">
    <h2 class="cta__title" data-reveal>Build it now.</h2>
    <p class="cta__sub" data-reveal style="--reveal-delay:90ms">Free to start. No credit card.</p>
    <a href={SIGNUP_URL} class="btn btn-white" data-reveal style="--reveal-delay:180ms">Start building free →</a>
  </div>
</section>

<style lang="scss">
  .cta {
    position: relative;
    padding: 80px 0;
    background: var(--indigo);
    color: #fff;
    overflow: hidden;

    &__inner {
      position: relative;
      text-align: center;
    }

    &__title {
      font-family: var(--font-display);
      font-size: 54px;
      letter-spacing: -0.035em;
      font-weight: 800;
      margin: 0 0 14px;
    }

    &__sub {
      font-size: 17px;
      color: var(--on-indigo-sub);
      margin: 0 0 30px;
    }
  }

  @media (max-width: 900px) {
    .cta {
      padding: 64px 0;

      &__title {
        font-size: 40px;
      }
    }
  }
</style>
