---
// Each step carries a decorative line-art motif (drawn in the card corner).
const steps = [
  {
    n: '1',
    title: 'Describe or drag',
    body: 'Prompt the AI or drop blocks onto the canvas.',
    // sparkle — prompt the AI
    motif:
      '<path d="M12 2.5l1.9 5.7L19.5 10l-5.6 1.8L12 17.5l-1.9-5.7L4.5 10l5.6-1.8z"/><path d="M19.5 3.5l.7 2.1 2.1.7-2.1.7-.7 2.1-.7-2.1-2.1-.7 2.1-.7z"/>',
  },
  {
    n: '2',
    title: 'Shape & connect',
    body: 'Refine visually and wire content to the CMS.',
    // connected nodes — wire content together
    motif:
      '<circle cx="6" cy="7" r="2.4"/><circle cx="18" cy="6" r="2.4"/><circle cx="13" cy="18" r="2.4"/><path d="M8.3 7.7l7.4-1.2M16.6 8.2l-2.9 7.5M7.6 9.1l4.7 7.3"/>',
  },
  {
    n: '3',
    title: 'Publish',
    body: "One click and you're live on your domain.",
    // rocket — go live
    motif:
      '<path d="M6 14.5c-1.3 1.5-1.3 4.7-1.3 4.7s3.2 0 4.7-1.3m-3.4-3.4a10.5 10.5 0 0 1 10.5-10.5c2.9 0 4.5 1.6 4.5 4.5a10.5 10.5 0 0 1-10.5 10.5z"/><circle cx="15.3" cy="8.7" r="1.6"/>',
  },
];
---

<section class="how" id="how">
  <div class="container">
    <header class="how__head" data-reveal>
      <div class="how__eyebrow">How it works</div>
      <h2 class="how__title">Three steps. One live site.</h2>
    </header>

    <div class="how__grid">
      {
        steps.map((s, i) => (
          <article class="step" data-reveal style={`--reveal-delay:${i * 90}ms`}>
            <svg
              class="step__motif"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.4"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              set:html={s.motif}
            />
            <div class="step__num">{s.n}</div>
            <h3 class="step__title">{s.title}</h3>
            <p class="step__body">{s.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style lang="scss">
  .how {
    padding: 84px 0;
    background: var(--surface-offwhite);
    border-top: 1px solid var(--border-light);

    &__head {
      text-align: center;
      margin-bottom: 54px;
    }
    &__eyebrow {
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--indigo);
      margin-bottom: 14px;
    }
    &__title {
      font-family: var(--font-display);
      font-size: 48px;
      letter-spacing: -0.035em;
      font-weight: 700;
      margin: 0;
    }
    &__grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 18px;
    }
  }

  .step {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    background: #fff;
    border: 1px solid var(--border-card);
    border-radius: 18px;
    padding: 30px;
    transition:
      transform var(--transition),
      box-shadow var(--transition),
      border-color var(--transition);

    /* decorative line-art motif tucked into the corner */
    &__motif {
      position: absolute;
      top: -14px;
      right: -14px;
      width: 100px;
      height: 100px;
      z-index: 0;
      color: var(--indigo);
      opacity: 0.1;
      pointer-events: none;
      transition:
        opacity var(--transition),
        transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
    }

    &:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-hover);
      border-color: var(--lavender-surface);

      .step__motif {
        opacity: 0.22;
        transform: rotate(-6deg) scale(1.08);
      }
    }

    &__num,
    &__title,
    &__body {
      position: relative;
      z-index: 1;
    }

    &__num {
      font-family: var(--font-display);
      font-size: 46px;
      color: var(--indigo);
      line-height: 1;
      margin-bottom: 18px;
    }
    &__title {
      font-size: 20px;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin: 0 0 9px;
    }
    &__body {
      font-size: 15px;
      line-height: 1.55;
      color: var(--text-body);
      margin: 0;
    }
  }

  @media (max-width: 900px) {
    .how {
      padding: 64px 0;

      &__title {
        font-size: 36px;
      }
      &__grid {
        grid-template-columns: 1fr;
      }
    }
  }
</style>
