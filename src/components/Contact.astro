---
const topics = ['General enquiry', 'Sales & pricing', 'Support', 'Partnerships'];
---

<section class="contact" id="contact">
  <div class="container contact__grid">
    <div class="contact__intro" data-reveal>
      <div class="contact__eyebrow">Contact us</div>
      <h2 class="contact__title">Let's build something together.</h2>
      <p class="contact__lead">
        Questions about Pagistry, pricing, or a custom plan? Send us a note and we'll
        get back to you within one business day.
      </p>
      <p class="contact__email">
        Prefer email?
        <a href="mailto:alexandyrfreelance@gmail.com">alexandyrfreelance@gmail.com</a>
      </p>
    </div>

    <form class="contact__form" novalidate data-reveal style="--reveal-delay:120ms">
      <div class="form-fields">
        <div class="field-row">
          <label class="field">
            <span class="field__label">Name</span>
            <input type="text" name="name" placeholder="Jane Doe" required autocomplete="name" />
          </label>
          <label class="field">
            <span class="field__label">Email</span>
            <input
              type="email"
              name="email"
              placeholder="jane@company.com"
              required
              autocomplete="email"
            />
          </label>
        </div>

        <div class="field">
          <span class="field__label" id="topic-label">What's it about?</span>
          <div class="cselect">
            <button
              type="button"
              class="cselect__trigger"
              aria-haspopup="listbox"
              aria-expanded="false"
              aria-controls="topic-list"
              aria-labelledby="topic-label"
            >
              <span class="cselect__value">{topics[0]}</span>
              <svg
                class="cselect__chev"
                viewBox="0 0 16 16"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M4 6l4 4 4-4" />
              </svg>
            </button>
            <ul
              class="cselect__list"
              id="topic-list"
              role="listbox"
              aria-labelledby="topic-label"
              tabindex="-1"
            >
              {
                topics.map((t, i) => (
                  <li
                    class="cselect__option"
                    id={`topic-opt-${i}`}
                    role="option"
                    data-value={t}
                    aria-selected={i === 0 ? 'true' : 'false'}
                  >
                    <span>{t}</span>
                    <svg
                      class="cselect__check"
                      viewBox="0 0 16 16"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.9"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M13.5 4.5l-7 7L3 8" />
                    </svg>
                  </li>
                ))
              }
            </ul>
            <input type="hidden" name="topic" value={topics[0]} />
          </div>
        </div>

        <label class="field">
          <span class="field__label">Message</span>
          <textarea
            name="message"
            rows="4"
            placeholder="Tell us a little about what you're building…"
            required></textarea>
        </label>

        <button type="submit" class="btn btn-dark form-submit">Send message →</button>
      </div>

      <div class="form-success" hidden role="status">
        <div class="form-success__check" aria-hidden="true">✓</div>
        <h3>Message sent.</h3>
        <p>Thanks for reaching out — we'll reply within one business day.</p>
      </div>
    </form>
  </div>
</section>

<script>
  const form = document.querySelector<HTMLFormElement>('.contact__form');
  if (form) {
    const fields = form.querySelector<HTMLElement>('.form-fields');
    const success = form.querySelector<HTMLElement>('.form-success');
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      // Demo: no backend wired up — show the success state.
      if (fields) fields.hidden = true;
      if (success) success.hidden = false;
    });
  }

  // ---- Custom select dropdown (replaces the native <select>) ----
  document.querySelectorAll<HTMLElement>('.cselect').forEach((cs) => {
    const trigger = cs.querySelector<HTMLButtonElement>('.cselect__trigger');
    const list = cs.querySelector<HTMLElement>('.cselect__list');
    const valueEl = cs.querySelector<HTMLElement>('.cselect__value');
    const hidden = cs.querySelector<HTMLInputElement>('input[type="hidden"]');
    const options = Array.from(cs.querySelectorAll<HTMLElement>('.cselect__option'));
    if (!trigger || !list || !valueEl || !options.length) return;

    let active = Math.max(
      0,
      options.findIndex((o) => o.getAttribute('aria-selected') === 'true'),
    );

    const isOpen = () => cs.classList.contains('is-open');
    const setActive = (i: number) => {
      active = Math.max(0, Math.min(options.length - 1, i));
      options.forEach((o, idx) => o.classList.toggle('is-active', idx === active));
      list.setAttribute('aria-activedescendant', options[active].id);
      options[active].scrollIntoView({ block: 'nearest' });
    };
    const open = () => {
      cs.classList.add('is-open');
      trigger.setAttribute('aria-expanded', 'true');
      setActive(options.findIndex((o) => o.getAttribute('aria-selected') === 'true'));
    };
    const close = () => {
      cs.classList.remove('is-open');
      trigger.setAttribute('aria-expanded', 'false');
      list.removeAttribute('aria-activedescendant');
      options.forEach((o) => o.classList.remove('is-active'));
    };
    const select = (i: number) => {
      options.forEach((o, idx) =>
        o.setAttribute('aria-selected', idx === i ? 'true' : 'false'),
      );
      const val = options[i].dataset.value || '';
      valueEl.textContent = val;
      if (hidden) hidden.value = val;
      close();
      trigger.focus();
    };

    trigger.addEventListener('click', () => (isOpen() ? close() : open()));
    options.forEach((o, i) => {
      o.addEventListener('click', () => select(i));
      o.addEventListener('mousemove', () => setActive(i));
    });
    trigger.addEventListener('keydown', (e) => {
      if (!isOpen()) {
        if (['ArrowDown', 'ArrowUp', 'Enter', ' '].includes(e.key)) {
          e.preventDefault();
          open();
        }
        return;
      }
      switch (e.key) {
        case 'ArrowDown':
          e.preventDefault();
          setActive(active + 1);
          break;
        case 'ArrowUp':
          e.preventDefault();
          setActive(active - 1);
          break;
        case 'Home':
          e.preventDefault();
          setActive(0);
          break;
        case 'End':
          e.preventDefault();
          setActive(options.length - 1);
          break;
        case 'Enter':
        case ' ':
          e.preventDefault();
          select(active);
          break;
        case 'Escape':
          e.preventDefault();
          close();
          break;
        case 'Tab':
          close();
          break;
      }
    });
    document.addEventListener('click', (e) => {
      if (!cs.contains(e.target as Node)) close();
    });
  });
</script>

<style lang="scss">
  .contact {
    padding: 84px 0;
    background: var(--surface-offwhite);
    border-top: 1px solid var(--border-light);
  }

  .contact__grid {
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    gap: 56px;
    align-items: start;
  }

  /* Intro column */
  .contact__eyebrow {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--indigo);
    margin-bottom: 14px;
  }
  .contact__title {
    font-family: var(--font-display);
    font-size: 44px;
    line-height: 1.04;
    letter-spacing: -0.035em;
    font-weight: 700;
    margin: 0 0 18px;
    max-width: 12em;
  }
  .contact__lead {
    font-size: 16.5px;
    line-height: 1.55;
    color: var(--text-body);
    margin: 0;
    max-width: 34em;
  }
  .contact__email {
    font-size: 15px;
    color: var(--text-body);
    margin: 18px 0 0;

    a {
      color: var(--indigo);
      font-weight: 600;
      text-decoration: underline;
      text-underline-offset: 2px;
    }
  }

  /* Form card */
  .contact__form {
    background: #fff;
    border: 1px solid var(--border-card);
    border-radius: var(--r-card);
    padding: 32px;
    box-shadow: 0 18px 50px -34px rgba(16, 16, 22, 0.18);
  }

  .form-fields {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  /* explicit display above would otherwise beat the [hidden] attribute */
  .contact__form [hidden] {
    display: none;
  }
  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .field__label {
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
  }

  .field input,
  .field textarea {
    width: 100%;
    font-family: inherit;
    font-size: 15px;
    color: var(--ink);
    background: var(--surface-gray);
    border: 1px solid transparent;
    border-radius: 12px;
    padding: 13px 15px;
    transition:
      border-color var(--transition),
      background var(--transition),
      box-shadow var(--transition);
  }
  .field textarea {
    resize: vertical;
    min-height: 110px;
  }
  .field input::placeholder,
  .field textarea::placeholder {
    color: #9a9aa3;
  }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    background: #fff;
    border-color: var(--indigo);
    box-shadow: 0 0 0 4px rgba(91, 61, 245, 0.14);
  }

  /* Custom dropdown (styled replacement for the native <select>) */
  .cselect {
    position: relative;

    &__trigger {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      font-family: inherit;
      font-size: 15px;
      color: var(--ink);
      text-align: left;
      background: var(--surface-gray);
      border: 1px solid transparent;
      border-radius: 12px;
      padding: 13px 15px;
      cursor: pointer;
      transition:
        border-color var(--transition),
        background var(--transition),
        box-shadow var(--transition);
    }

    &__chev {
      width: 16px;
      height: 16px;
      flex: none;
      color: var(--text-body);
      transition: transform var(--transition);
    }

    &.is-open &__trigger,
    &__trigger:focus-visible {
      outline: none;
      background: #fff;
      border-color: var(--indigo);
      box-shadow: 0 0 0 4px rgba(91, 61, 245, 0.14);
    }
    &.is-open &__chev {
      transform: rotate(180deg);
    }

    &__list {
      position: absolute;
      top: calc(100% + 8px);
      left: 0;
      right: 0;
      z-index: 30;
      margin: 0;
      padding: 6px;
      list-style: none;
      background: #fff;
      border: 1px solid var(--border-card);
      border-radius: 14px;
      box-shadow: 0 18px 44px -20px rgba(16, 16, 22, 0.28);
      opacity: 0;
      visibility: hidden;
      transform: translateY(-6px) scale(0.98);
      transform-origin: top center;
      transition:
        opacity 0.2s ease,
        transform 0.28s cubic-bezier(0.16, 1, 0.3, 1),
        visibility 0s linear 0.28s;
    }
    &.is-open &__list {
      opacity: 1;
      visibility: visible;
      transform: none;
      transition:
        opacity 0.2s ease,
        transform 0.28s cubic-bezier(0.16, 1, 0.3, 1),
        visibility 0s;
    }

    &__option {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      padding: 10px 12px;
      border-radius: 9px;
      font-size: 14.5px;
      color: var(--ink);
      cursor: pointer;
      transition:
        background var(--transition),
        color var(--transition);

      &:hover,
      &.is-active {
        background: var(--lavender-surface);
      }
      &[aria-selected='true'] {
        color: var(--indigo);
        font-weight: 600;
      }
    }

    &__check {
      width: 16px;
      height: 16px;
      flex: none;
      color: var(--indigo);
      opacity: 0;
    }
    &__option[aria-selected='true'] &__check {
      opacity: 1;
    }
  }

  .form-submit {
    width: 100%;
    margin-top: 4px;
  }

  /* Success state */
  .form-success {
    text-align: center;
    padding: 18px 8px;
  }
  .form-success__check {
    width: 56px;
    height: 56px;
    margin: 0 auto 18px;
    border-radius: 999px;
    background: var(--lavender-surface);
    color: var(--indigo);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 26px;
    font-weight: 700;
  }
  .form-success h3 {
    font-family: var(--font-display);
    font-size: 24px;
    letter-spacing: -0.02em;
    margin: 0 0 8px;
  }
  .form-success p {
    font-size: 15px;
    color: var(--text-body);
    margin: 0;
    line-height: 1.55;
  }

  @media (max-width: 900px) {
    .contact {
      padding: 64px 0;
    }
    .contact__grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }
    .contact__title {
      font-size: 36px;
    }
  }

  @media (max-width: 560px) {
    .contact__form {
      padding: 24px;
    }
    .field-row {
      grid-template-columns: 1fr;
    }
  }
</style>
