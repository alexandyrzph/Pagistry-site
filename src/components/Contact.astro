---
const topics = ['General enquiry', 'Sales & pricing', 'Support', 'Partnerships'];
---

<section class="contact" id="contact">
  <div class="container contact__grid">
    <div class="contact__intro" data-reveal>
      <div class="contact__eyebrow">Contact us</div>
      <h2 class="contact__title">Let's build something together.</h2>
      <p class="contact__lead">
        Questions about Pagistry, pricing, or a custom plan? Send us a note and we'll
        get back to you within one business day.
      </p>

      <ul class="contact__meta">
        <li>
          <span class="contact__meta-icon" aria-hidden="true">✉</span>
          <a href="mailto:hello@pagistry.com">hello@pagistry.com</a>
        </li>
        <li>
          <span class="contact__meta-icon" aria-hidden="true">◷</span>
          <span>Mon–Fri · 9:00–18:00</span>
        </li>
      </ul>
    </div>

    <form class="contact__form" novalidate data-reveal style="--reveal-delay:120ms">
      <div class="form-fields">
        <div class="field-row">
          <label class="field">
            <span class="field__label">Name</span>
            <input type="text" name="name" placeholder="Jane Doe" required autocomplete="name" />
          </label>
          <label class="field">
            <span class="field__label">Email</span>
            <input
              type="email"
              name="email"
              placeholder="jane@company.com"
              required
              autocomplete="email"
            />
          </label>
        </div>

        <label class="field">
          <span class="field__label">What's it about?</span>
          <div class="select-wrap">
            <select name="topic">
              {topics.map((t) => <option value={t}>{t}</option>)}
            </select>
            <svg class="select-chev" width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
              <path
                d="M2.5 4.5 6 8l3.5-3.5"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </div>
        </label>

        <label class="field">
          <span class="field__label">Message</span>
          <textarea
            name="message"
            rows="4"
            placeholder="Tell us a little about what you're building…"
            required></textarea>
        </label>

        <button type="submit" class="btn btn-dark form-submit">Send message →</button>
      </div>

      <div class="form-success" hidden role="status">
        <div class="form-success__check" aria-hidden="true">✓</div>
        <h3>Message sent.</h3>
        <p>Thanks for reaching out — we'll reply within one business day.</p>
      </div>
    </form>
  </div>
</section>

<script>
  const form = document.querySelector<HTMLFormElement>('.contact__form');
  if (form) {
    const fields = form.querySelector<HTMLElement>('.form-fields');
    const success = form.querySelector<HTMLElement>('.form-success');
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      // Demo: no backend wired up — show the success state.
      if (fields) fields.hidden = true;
      if (success) success.hidden = false;
    });
  }
</script>

<style lang="scss">
  .contact {
    padding: 84px 0;
    background: var(--surface-offwhite);
    border-top: 1px solid var(--border-light);
  }

  .contact__grid {
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    gap: 56px;
    align-items: start;
  }

  /* Intro column */
  .contact__eyebrow {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--indigo);
    margin-bottom: 14px;
  }
  .contact__title {
    font-family: var(--font-display);
    font-size: 44px;
    line-height: 1.04;
    letter-spacing: -0.035em;
    font-weight: 700;
    margin: 0 0 18px;
    max-width: 12em;
  }
  .contact__lead {
    font-size: 16.5px;
    line-height: 1.55;
    color: var(--text-body);
    margin: 0 0 30px;
    max-width: 34em;
  }
  .contact__meta {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .contact__meta li {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 15px;
    color: var(--text-body);
  }
  .contact__meta a:hover {
    color: var(--indigo);
  }
  .contact__meta-icon {
    flex: none;
    width: 38px;
    height: 38px;
    border-radius: 10px;
    background: var(--lavender-surface);
    color: var(--indigo);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
  }

  /* Form card */
  .contact__form {
    background: #fff;
    border: 1px solid var(--border-card);
    border-radius: var(--r-card);
    padding: 32px;
    box-shadow: 0 18px 50px -34px rgba(16, 16, 22, 0.18);
  }

  .form-fields {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  /* explicit display above would otherwise beat the [hidden] attribute */
  .contact__form [hidden] {
    display: none;
  }
  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .field__label {
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
  }

  .field input,
  .field textarea,
  .field select {
    width: 100%;
    font-family: inherit;
    font-size: 15px;
    color: var(--ink);
    background: var(--surface-gray);
    border: 1px solid transparent;
    border-radius: 12px;
    padding: 13px 15px;
    transition:
      border-color var(--transition),
      background var(--transition),
      box-shadow var(--transition);
  }
  .field textarea {
    resize: vertical;
    min-height: 110px;
  }
  .field input::placeholder,
  .field textarea::placeholder {
    color: #9a9aa3;
  }
  .field input:focus,
  .field textarea:focus,
  .field select:focus {
    outline: none;
    background: #fff;
    border-color: var(--indigo);
    box-shadow: 0 0 0 4px rgba(91, 61, 245, 0.14);
  }

  .select-wrap {
    position: relative;
  }
  .select-wrap select {
    appearance: none;
    -webkit-appearance: none;
    cursor: pointer;
    padding-right: 38px;
  }
  .select-chev {
    position: absolute;
    right: 15px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-body);
    pointer-events: none;
  }

  .form-submit {
    width: 100%;
    margin-top: 4px;
  }

  /* Success state */
  .form-success {
    text-align: center;
    padding: 18px 8px;
  }
  .form-success__check {
    width: 56px;
    height: 56px;
    margin: 0 auto 18px;
    border-radius: 999px;
    background: var(--lavender-surface);
    color: var(--indigo);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 26px;
    font-weight: 700;
  }
  .form-success h3 {
    font-family: var(--font-display);
    font-size: 24px;
    letter-spacing: -0.02em;
    margin: 0 0 8px;
  }
  .form-success p {
    font-size: 15px;
    color: var(--text-body);
    margin: 0;
    line-height: 1.55;
  }

  @media (max-width: 900px) {
    .contact {
      padding: 64px 0;
    }
    .contact__grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }
    .contact__title {
      font-size: 36px;
    }
  }

  @media (max-width: 560px) {
    .contact__form {
      padding: 24px;
    }
    .field-row {
      grid-template-columns: 1fr;
    }
  }
</style>
