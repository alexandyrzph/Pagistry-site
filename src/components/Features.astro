---
// Cards 2–5 of the bento grid (card 1 is the tall dark feature, rendered inline).
const cards = [
  {
    variant: 'lavender',
    icon: '▦',
    title: 'Visual blocks',
    body: 'Drag heroes, grids and forms. Pixel control, zero code.',
  },
  {
    variant: 'gray',
    icon: '⛁',
    title: 'Built-in CMS',
    body: 'Model content once, reuse it everywhere.',
  },
  {
    variant: 'gray',
    icon: '⟲',
    title: 'Components',
    body: 'Save any block, edits sync across pages.',
  },
  {
    variant: 'indigo',
    icon: '↗',
    title: 'One-click publish',
    body: 'Live on your domain, instantly.',
  },
];
---

<section class="features" id="features">
  <div class="container">
    <h2 class="features__heading" data-reveal>Everything you need to design, manage and ship.</h2>

    <div class="bento">
      <article class="card card--tall card--dark" data-reveal>
        <div class="card__icon" aria-hidden="true">✦</div>
        <div>
          <h3 class="card__title card__title--lg">AI that builds pages</h3>
          <p class="card__body">
            Type a prompt and watch sections, components and full pages appear on the
            canvas — editable, never locked.
          </p>
        </div>
      </article>

      {
        cards.map((c, i) => (
          <article class={`card card--${c.variant}`} data-reveal style={`--reveal-delay:${(i + 1) * 80}ms`}>
            <div class="card__icon" aria-hidden="true">
              {c.icon}
            </div>
            <h3 class="card__title">{c.title}</h3>
            <p class="card__body">{c.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style lang="scss">
  .features {
    padding: 84px 0;
  }

  .features__heading {
    font-family: var(--font-display);
    font-size: 52px;
    line-height: 1;
    letter-spacing: -0.035em;
    font-weight: 700;
    margin: 0;
    max-width: 14em;
  }

  .bento {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    grid-auto-rows: minmax(180px, auto);
    gap: 16px;
    margin-top: 46px;
  }

  .card {
    border-radius: var(--r-card);
    padding: 28px;
    transition:
      transform var(--transition),
      box-shadow var(--transition);
  }
  .card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-hover);
  }

  .card--tall {
    grid-row: span 2;
    padding: 32px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .card--dark {
    background: var(--ink);
    color: #fff;
  }
  .card--lavender {
    background: var(--lavender-surface);
  }
  .card--gray {
    background: var(--surface-gray);
  }
  .card--indigo {
    background: var(--indigo);
    color: #fff;
  }

  .card__icon {
    font-size: 22px;
    margin-bottom: 14px;
    color: var(--indigo);
  }
  /* Icons inside colored cards inherit white */
  .card--dark .card__icon,
  .card--indigo .card__icon {
    color: inherit;
  }
  .card--dark .card__icon {
    font-size: 24px;
    margin-bottom: 0;
  }

  .card__title {
    font-size: 19px;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 8px;
  }
  .card__title--lg {
    font-family: var(--font-display);
    font-size: 30px;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 0 0 12px;
  }

  .card__body {
    font-size: 14.5px;
    line-height: 1.5;
    color: var(--text-body);
    margin: 0;
  }
  .card--dark .card__body {
    font-size: 15.5px;
    line-height: 1.55;
    color: var(--dark-card-body);
  }
  .card--indigo .card__body {
    color: var(--on-indigo-link);
  }

  @media (max-width: 900px) {
    .features {
      padding: 64px 0;
    }
    .features__heading {
      font-size: 38px;
    }
    /* Single column, tall card first (it is already first in the DOM) */
    .bento {
      grid-template-columns: 1fr;
      grid-auto-rows: auto;
    }
    .card--tall {
      grid-row: auto;
    }
  }

  @media (max-width: 560px) {
    .features__heading {
      font-size: 30px;
    }
  }
</style>
